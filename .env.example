# Copiar a .env y ajustar. Lo leen docker-compose.yml y la app Next.

# ---- Base de datos (MariaDB) ----
MARIADB_ROOT_PASSWORD=root
MARIADB_DATABASE=gqg
MARIADB_USER=gqg
MARIADB_PASSWORD=gqg

# Puertos en el host (cambiar si estan ocupados)
DB_PORT=3307
ADMINER_PORT=8081
APP_PORT=3000

# Conexion que usa la app (mysql2). En docker el host es "db".
DB_HOST=db
DB_USER=gqg
DB_PASSWORD=gqg
DB_NAME=gqg

# ---- Auth (usuario admin desde el entorno, como alilaurisys) ----
ADMIN_USER=admin
ADMIN_PASSWORD=gqg2026
AUTH_SECRET=cambiar-por-una-cadena-larga-y-secreta
